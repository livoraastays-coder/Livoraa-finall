# Copy this file to .env.local and fill in real values.

# Public site URL (used for canonical URLs, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://www.livoraastays.com

# --- Sanity CMS ---
# Create a free project at https://www.sanity.io/manage, then fill these in.
# Leaving NEXT_PUBLIC_SANITY_PROJECT_ID empty is a supported, intentional
# state: the site runs entirely on the static fallback data in
# lib/data/fallback/ until this is set (see README.md "Sanity CMS" section).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# --- Server-only secrets (never prefix these with NEXT_PUBLIC_) ---
# Optional: a Sanity API token with "Viewer" access, only needed if you
# want the site to read draft/unpublished content. Create one under
# https://www.sanity.io/manage → your project → API → Tokens.
# SANITY_API_READ_TOKEN=

# Add your email provider's API key here once you wire up
# app/api/contact/route.ts to actually send emails (e.g. Resend, SendGrid).
# This is never read by frontend code, so it stays out of the browser bundle.
# RESEND_API_KEY=your-key-here
